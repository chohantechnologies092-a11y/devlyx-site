rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: checks if the user is logged in as Admin via Firebase Auth
    function isAdmin() {
      return request.auth != null;
    }

    // 1. Blogs / Posts
    // Anyone can read blogs, but only Admin can write (create/update/delete)
    match /posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 2. Portfolio / Projects
    // Anyone can read projects, but only Admin can write (create/update/delete)
    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 3. Team Members
    // Anyone can view team members, but only Admin can write
    match /teamMembers/{memberId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 4. Agent Training (AI bot settings)
    // Anyone can read, but only Admin can write
    match /agentTraining/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 5. Analytics (Overview statistics)
    // Allow users to update stats (e.g. increment visits or leads counters),
    // but only Admin can read the overview stats on the dashboard
    match /analytics/overview {
      allow read: if isAdmin();
      allow write: if true; 
    }

    // 6. Visitor Analytics (Visits logs)
    // Anyone can create visit logs or update their own visit duration (timeOnSite),
    // but only Admin can read all visits logs or clear them
    match /visits/{visitId} {
      allow create: if true;
      allow update: if true; 
      allow read, delete: if isAdmin();
    }

    // 7. Contact Leads
    // Anyone can submit a contact form (create lead), but only Admin can read or manage leads
    match /leads/{leadId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // 8. Newsletter & Subscribers
    // Anyone can subscribe (create), but only Admin can read or manage
    match /subscribers/{subscriberId} {
      allow create: if true;
      allow read, write: if isAdmin();
    }
    match /newsletter/{docId} {
      allow create: if true;
      allow read, write: if isAdmin();
    }

    // 9. AI Chats & Messages
    // Anyone can chat (read/write in chats & sub-messages) to allow the chatbot to function,
    // and Admin can also read/write all chats
    match /chats/{sessionId} {
      allow read, write: if true;
      match /messages/{messageId} {
        allow read, write: if true;
      }
    }

    // 10. Clients
    // Anyone can read clients, but only Admin can write (create/update/delete)
    match /clients/{clientId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
